// Prisma schema for COUPONUS BD — MySQL Provider
generator client {
  provider        = "prisma-client-js"
  engineType      = "client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Users ──────────────────────────────────────────────
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  fullName      String
  phone         String?
  avatarUrl     String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  reviews       Review[]
  vouchers      Voucher[]
  merchant      Merchant?

  @@index([email])
  @@map("users")
}

enum UserRole {
  CUSTOMER
  MERCHANT
  ADMIN
}

// ── Merchants ──────────────────────────────────────────
model Merchant {
  id            String    @id @default(uuid())
  userId        String    @unique
  businessName  String
  description   String?   @db.Text
  logoUrl       String?
  coverUrl      String?
  phone         String?
  website       String?
  address       String
  area          String
  city          String
  latitude      Decimal?  @db.Decimal(10, 8)
  longitude     Decimal?  @db.Decimal(11, 8)
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  commissionRate Decimal  @default(25) @db.Decimal(5, 2)
  ratingAvg     Decimal   @default(0) @db.Decimal(3, 2)
  ratingCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  deals         Deal[]
  payouts       Payout[]
  promotions    Promotion[]

  @@index([city, area])
  @@index([isActive, isVerified])
  @@map("merchants")
}

// ── Promotions (Slot-Based) ───────────────────────────
model Promotion {
  id                   String                  @id @default(uuid())
  merchantId           String
  placement            PromotionPlacement
  title                String
  imageUrl             String?                 @db.LongText
  linkType             PromotionLinkType       @default(DEAL)
  linkHref             String

  // Slot booking: 1 day + 1 slot per record
  slotDate             DateTime                @db.Date
  slotTier             PromotionSlotTier
  price                Decimal                 @db.Decimal(12, 2)

  // Template fields (optional branded creative)
  templateStyleKey     String?
  templateHeadline     String?
  templateSubtext      String?
  templateDiscountText String?
  templateShopLogo     String?                 @db.LongText
  templateProductImage String?                 @db.LongText

  // Status
  status               PromotionStatus         @default(PENDING_REVIEW)
  paymentStatus        PromotionPaymentStatus  @default(PENDING)
  adminNote            String?                 @db.Text

  // Grouping for multi-day bookings (extensions)
  parentId             String?

  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  approvedAt           DateTime?

  merchant             Merchant                @relation(fields: [merchantId], references: [id])
  parent               Promotion?              @relation("PromotionExtensions", fields: [parentId], references: [id])
  extensions           Promotion[]             @relation("PromotionExtensions")

  @@index([merchantId])
  @@index([slotDate, slotTier, placement])
  @@index([status, paymentStatus])
  @@index([parentId])
  @@map("promotions")
}

enum PromotionPlacement {
  MAIN_BANNER
  SPONSORED_VOUCHER
}

enum PromotionSlotTier {
  LATE_NIGHT
  MORNING
  AFTERNOON
  PRIME
}

enum PromotionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum PromotionPaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PromotionLinkType {
  SHOP
  DEAL
  CUSTOM
}

// ── Categories ─────────────────────────────────────────
model Category {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  description   String?
  iconName      String?
  color         String?
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  parentId      String?
  createdAt     DateTime  @default(now())

  parent        Category? @relation("CategoryChildren", fields: [parentId], references: [id])
  children      Category[] @relation("CategoryChildren")
  deals         Deal[]

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

// ── Deals ──────────────────────────────────────────────
model Deal {
  id              String       @id @default(uuid())
  merchantId      String
  categoryId      String
  title           String
  slug            String       @unique
  description     String       @db.Text
  finePrint       String?      @db.Text
  highlights      Json?
  images          Json?
  originalPrice   Decimal      @db.Decimal(12, 2)
  dealPrice       Decimal      @db.Decimal(12, 2)
  discountPercent Int
  extraDiscount   Decimal?     @db.Decimal(12, 2)
  extraDiscountLabel String?
  quantityTotal   Int          @default(0)
  quantitySold    Int          @default(0)
  maxPerUser      Int          @default(5)
  startDate       DateTime
  endDate         DateTime
  status          DealStatus   @default(ACTIVE)
  isFeatured      Boolean      @default(false)
  isSponsored     Boolean      @default(false)
  viewCount       Int          @default(0)
  ratingAvg       Decimal      @default(0) @db.Decimal(3, 2)
  ratingCount     Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  merchant        Merchant     @relation(fields: [merchantId], references: [id])
  category        Category     @relation(fields: [categoryId], references: [id])
  options         DealOption[]
  orderItems      OrderItem[]
  reviews         Review[]

  @@index([slug])
  @@index([merchantId])
  @@index([categoryId])
  @@index([status, isFeatured])
  @@index([status, startDate, endDate])
  @@fulltext([title, description])
  @@map("deals")
}

enum DealStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  SOLD_OUT
}

// ── Deal Options ───────────────────────────────────────
model DealOption {
  id              String    @id @default(uuid())
  dealId          String
  title           String
  originalPrice   Decimal   @db.Decimal(12, 2)
  dealPrice       Decimal   @db.Decimal(12, 2)
  boughtCount     Int       @default(0)
  sortOrder       Int       @default(0)
  isActive        Boolean   @default(true)

  deal            Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]

  @@index([dealId])
  @@map("deal_options")
}

// ── Orders ─────────────────────────────────────────────
model Order {
  id              String        @id @default(uuid())
  userId          String
  totalAmount     Decimal       @db.Decimal(12, 2)
  serviceFee      Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  promoCode       String?
  paymentMethod   String?
  paymentId       String?
  paymentStatus   PaymentStatus @default(PENDING)
  status          OrderStatus   @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  items           OrderItem[]
  vouchers        Voucher[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ── Order Items ────────────────────────────────────────
model OrderItem {
  id            String    @id @default(uuid())
  orderId       String
  dealId        String
  optionId      String
  quantity      Int
  unitPrice     Decimal   @db.Decimal(12, 2)
  totalPrice    Decimal   @db.Decimal(12, 2)

  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deal          Deal      @relation(fields: [dealId], references: [id])
  option        DealOption @relation(fields: [optionId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ── Vouchers ───────────────────────────────────────────
model Voucher {
  id            String        @id @default(uuid())
  orderId       String
  userId        String
  voucherCode   String        @unique
  qrData        String        @db.Text
  status        VoucherStatus @default(ACTIVE)
  expiryDate    DateTime
  redeemedAt    DateTime?
  createdAt     DateTime      @default(now())

  order         Order         @relation(fields: [orderId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@index([voucherCode])
  @@index([userId, status])
  @@map("vouchers")
}

enum VoucherStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  REFUNDED
}

// ── Reviews ────────────────────────────────────────────
model Review {
  id            String    @id @default(uuid())
  userId        String
  dealId        String
  rating        Int
  comment       String?   @db.Text
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  deal          Deal      @relation(fields: [dealId], references: [id])

  @@unique([userId, dealId])
  @@index([dealId])
  @@map("reviews")
}

// ── Payouts ────────────────────────────────────────────
model Payout {
  id            String        @id @default(uuid())
  merchantId    String
  amount        Decimal       @db.Decimal(12, 2)
  bkashNumber   String?
  status        PayoutStatus  @default(PENDING)
  processedAt   DateTime?
  createdAt     DateTime      @default(now())

  merchant      Merchant      @relation(fields: [merchantId], references: [id])

  @@index([merchantId, status])
  @@map("payouts")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ── Analytics Events ───────────────────────────────────
model AnalyticsEvent {
  id          String    @id @default(uuid())
  eventType   String
  eventData   Json?
  userId      String?
  sessionId   String?
  ipAddress   String?
  userAgent   String?   @db.Text
  page        String?
  referrer    String?
  createdAt   DateTime  @default(now())

  @@index([eventType, createdAt])
  @@index([userId])
  @@map("analytics_events")
}
