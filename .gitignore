# Dependencies
node_modules/
.pnp.*

# Next.js — exclude dev caches and build traces (Turbopack SST files are 200MB+)
# Only .next/server/ and .next/static/ are needed for production
frontend/.next/cache/
frontend/.next/dev/
frontend/.next/trace
frontend/.next/trace-build
frontend/.next/turbopack
frontend/out/

# Environment — production env IS committed (no secrets in it)
.env
.env.local
.env.*.local
# .env.production is NOT ignored — needed on Hostinger

# Logs
npm-debug.log*
dev.log
dev.err.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
.gemini/
*.swp
*.swo

# Prisma
backend/prisma/migrations/

# Scratch/temp
scratch/
frontend/scratch/
