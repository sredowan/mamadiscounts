# Hostinger production environment for COUPONUS BD frontend
# NEXT_PUBLIC_* values are baked into the Next.js production build.

NODE_ENV="production"

# API URL — empty string means frontend uses relative /api paths,
# which the unified server.js proxies to the Express backend.
NEXT_PUBLIC_API_URL=""

# Domain for OG images and canonical URLs
NEXT_PUBLIC_SITE_URL="https://peachpuff-lark-454026.hostingersite.com"
