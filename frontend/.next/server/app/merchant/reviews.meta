{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/merchant/layout,_N_T_/merchant/reviews/layout,_N_T_/merchant/reviews/page,_N_T_/merchant/reviews"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/merchant/reviews/__PAGE__",
    "/merchant/reviews",
    "/merchant",
    "/_index",
    "/_head"
  ]
}